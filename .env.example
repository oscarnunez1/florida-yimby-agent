# Copy to .env and fill in values
ANTHROPIC_API_KEY=sk-ant-...

# Flask session security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me

# Tavily web search enrichment (https://tavily.com)
TAVILY_API_KEY=tvly-your-key-here

# Optional: override DB path (default: db.sqlite in project root)
# DB_PATH=db.sqlite

# Optional: override Flask port (default: 5000)
# FLASK_PORT=5000
